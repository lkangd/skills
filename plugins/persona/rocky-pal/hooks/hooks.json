{
  "description": "Rocky-Pal auto injection hooks",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3",
            "args": ["${CLAUDE_PLUGIN_ROOT}/hooks/user_prompt_submit.py"],
            "timeout": 20
          }
        ]
      }
    ]
  }
}
